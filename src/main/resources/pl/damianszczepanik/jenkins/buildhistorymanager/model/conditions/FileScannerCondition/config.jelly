<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form">

    <f:entry title="List of include patterns to use" field="includePattern">
        <f:textbox/>
    </f:entry>
    <f:entry title="List of exclude patterns to use" field="excludePattern">
        <f:textbox/>
    </f:entry>
    <f:entry title="Patterns are matched in a case sensitive way"
             field="caseSensitive">
        <f:checkbox default="true"/>
    </f:entry>
</j:jelly>
